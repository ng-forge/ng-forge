{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/docs/src",
  "tags": [],
  "implicitDependencies": [
    "sandbox-harness",
    "examples-material",
    "examples-bootstrap",
    "examples-primeng",
    "examples-ionic",
    "sandbox-adapter-material",
    "sandbox-adapter-bootstrap",
    "sandbox-adapter-primeng",
    "sandbox-adapter-ionic"
  ],
  "targets": {
    "generate-api-docs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx apps/docs/scripts/generate-api-docs.ts",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{projectRoot}/public/content/api"]
    },
    "generate-llms-full": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx apps/docs/scripts/generate-llms-full.ts",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{projectRoot}/public/llms-full.txt"]
    },
    "build": {
      "executor": "@analogjs/platform:vite",
      "options": {
        "configFile": "apps/docs/vite.config.ts",
        "main": "apps/docs/src/main.ts",
        "outputPath": "dist/apps/docs/client",
        "tsConfig": "apps/docs/tsconfig.app.json"
      },
      "defaultConfiguration": "production",
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "sourcemap": false,
          "mode": "production"
        }
      },
      "outputs": ["{workspaceRoot}/dist/apps/docs"]
    },
    "serve": {
      "executor": "@analogjs/platform:vite-dev-server",
      "continuous": true,
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "docs:build",
        "port": 4200
      },
      "configurations": {
        "development": {
          "buildTarget": "docs:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "docs:build:production"
        }
      }
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "docs:build"
      }
    },
    "postbuild:search": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npx pagefind --site dist/apps/docs/browser --output-subdir pagefind",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "docs:build",
        "port": 4200,
        "staticFilePath": "dist/apps/docs/browser",
        "spa": true
      }
    }
  }
}
