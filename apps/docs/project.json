{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/docs/src",
  "tags": [],
  "implicitDependencies": [
    "sandbox-harness",
    "examples-material",
    "examples-bootstrap",
    "examples-primeng",
    "examples-ionic",
    "sandbox-adapter-material",
    "sandbox-adapter-bootstrap",
    "sandbox-adapter-primeng",
    "sandbox-adapter-ionic"
  ],
  "targets": {
    "generate-llms-full": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx apps/docs/scripts/generate-llms-full.ts",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{projectRoot}/public/llms-full.txt"]
    },
    "build": {
      "executor": "@ng-doc/builder:application",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["^build", "generate-llms-full"],
      "options": {
        "outputPath": "dist/apps/docs",
        "browser": "apps/docs/src/main.ts",
        "server": "apps/docs/src/main.server.ts",
        "tsConfig": "apps/docs/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "prerender": true,
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/docs/public"
          },
          {
            "glob": "**/*",
            "input": "dist/ng-doc/docs/assets",
            "output": "assets/ng-doc"
          },
          {
            "glob": "**/*",
            "input": "node_modules/@ng-doc/ui-kit/assets",
            "output": "assets/ng-doc/ui-kit"
          }
        ],
        "styles": [
          "apps/docs/src/styles.scss",
          {
            "input": "apps/docs/src/styles/adapter-material.scss",
            "bundleName": "material",
            "inject": false
          },
          {
            "input": "apps/docs/src/styles/adapter-bootstrap.scss",
            "bundleName": "bootstrap",
            "inject": false
          },
          {
            "input": "apps/docs/src/styles/adapter-primeng.scss",
            "bundleName": "primeng",
            "inject": false
          },
          {
            "input": "apps/docs/src/styles/adapter-ionic.scss",
            "bundleName": "ionic",
            "inject": false
          }
        ],
        "stylePreprocessorOptions": {
          "includePaths": ["internal/styling/src"]
        },
        "allowedCommonJsDependencies": ["dayjs", "@braintree/sanitize-url", "dompurify", "cytoscape-cose-bilkent", "elkjs", "@ng-doc/core"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2.5mb",
              "maximumError": "5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "20kb",
              "maximumError": "40kb"
            }
          ],
          "outputHashing": "all",
          "baseHref": "/dynamic-forms/",
          "ngDoc": {
            "config": "apps/docs/ng-doc.config.ts"
          }
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "prerender": false,
          "ngDoc": {
            "config": "apps/docs/ng-doc.config.ts"
          }
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@ng-doc/builder:dev-server",
      "options": {
        "buildTarget": "docs:build:development"
      },
      "configurations": {
        "production": {
          "buildTarget": "docs:build:production"
        },
        "development": {
          "buildTarget": "docs:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "docs:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "ng-doc:rebuild": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["rm -rf dist/ng-doc", "nx build docs"],
        "cwd": "{workspaceRoot}",
        "parallel": false
      },
      "outputs": ["{workspaceRoot}/dist/apps/docs"]
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "docs:build",
        "port": 4200,
        "staticFilePath": "dist/apps/docs/browser",
        "spa": true
      }
    }
  }
}
