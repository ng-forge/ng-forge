{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ng-forge/dynamic-forms": ["packages/dynamic-forms/src/index.ts"],
      "@ng-forge/dynamic-forms/integration": ["packages/dynamic-forms/integration/src/public_api.ts"],
      "@ng-forge/dynamic-forms/schema": ["packages/dynamic-forms/schema/src/public_api.ts"],
      "@ng-forge/dynamic-forms-bootstrap": ["packages/dynamic-forms-bootstrap/src/index.ts"],
      "@ng-forge/dynamic-forms-ionic": ["packages/dynamic-forms-ionic/src/index.ts"],
      "@ng-forge/dynamic-forms-material": ["packages/dynamic-forms-material/src/index.ts"],
      "@ng-forge/dynamic-forms-primeng": ["packages/dynamic-forms-primeng/src/index.ts"],
      "@ng-forge/dynamic-form-mcp": ["packages/dynamic-form-mcp/src/index.ts"],
      "@ng-forge/examples-material": ["internal/examples-material/src/index.ts"],
      "@ng-forge/examples-bootstrap": ["internal/examples-bootstrap/src/index.ts"],
      "@ng-forge/examples-primeng": ["internal/examples-primeng/src/index.ts"],
      "@ng-forge/examples-ionic": ["internal/examples-ionic/src/index.ts"],
      "@ng-forge/examples-shared-testing": ["internal/examples-shared-testing/src/index.ts"],
      "@ng-forge/examples-shared-ui": ["internal/examples-shared-ui/src/index.ts"],
      "@ng-forge/sandbox-harness": ["internal/sandbox-harness/src/index.ts"],
      "@ng-forge/sandbox-adapter-material": ["internal/sandbox-adapter-material/src/index.ts"],
      "@ng-forge/sandbox-adapter-bootstrap": ["internal/sandbox-adapter-bootstrap/src/index.ts"],
      "@ng-forge/sandbox-adapter-primeng": ["internal/sandbox-adapter-primeng/src/index.ts"],
      "@ng-forge/sandbox-adapter-ionic": ["internal/sandbox-adapter-ionic/src/index.ts"],
      "@ng-forge/examples-shared-testing/playwright-config": ["internal/examples-shared-testing/src/lib/playwright-config.ts"],
      "@ng-forge/styling": ["internal/styling/src/index.ts"],
      "@ng-forge/dynamic-forms/testing": ["packages/dynamic-forms/testing/src/public_api.ts"],
      "@ng-forge/utils": ["internal/utils/src/index.ts"],
      "@ng-forge/dynamic-forms-zod": ["internal/dynamic-forms-zod/src/index.ts"],
      "@ng-forge/dynamic-forms-zod/material": ["internal/dynamic-forms-zod/material/src/index.ts"],
      "@ng-forge/dynamic-forms-zod/bootstrap": ["internal/dynamic-forms-zod/bootstrap/src/index.ts"],
      "@ng-forge/dynamic-forms-zod/primeng": ["internal/dynamic-forms-zod/primeng/src/index.ts"],
      "@ng-forge/dynamic-forms-zod/ionic": ["internal/dynamic-forms-zod/ionic/src/index.ts"],
      "@ng-forge/dynamic-forms-zod/mcp": ["internal/dynamic-forms-zod/mcp/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
