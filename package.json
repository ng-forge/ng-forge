{
  "name": "@ng-forge/source",
  "type": "module",
  "version": "0.9.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "bash scripts/postinstall.sh",
    "build:libs": "nx run-many -t build -p dynamic-forms,dynamic-forms-material,dynamic-forms-bootstrap,dynamic-forms-primeng,dynamic-forms-ionic,dynamic-form-mcp,openapi-generator",
    "build:docs": "nx build docs",
    "build:examples": "nx build sandbox-examples",
    "build:all:prod": "pnpm run build:libs && pnpm run build:docs",
    "prepare:deploy": "node scripts/prepare-deploy.js",
    "deploy:prep": "pnpm run build:all:prod && pnpm run prepare:deploy",
    "serve:docs": "nx serve docs",
    "serve:ssr:docs": "node dist/apps/docs/server/server.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml,html,css,scss}\"",
    "test": "nx run-many -t test",
    "test:ci": "nx run-many -t test --configuration=ci",
    "test:coverage": "nx run-many -t test --configuration=ci --coverage",
    "test:watch": "nx run-many -t test --watch",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "e2e:all": "pnpm e2e:core && pnpm e2e:material && pnpm e2e:bootstrap && pnpm e2e:primeng && pnpm e2e:ionic",
    "e2e:all:update": "pnpm e2e:material:update && pnpm e2e:bootstrap:update && pnpm e2e:primeng:update && pnpm e2e:ionic:update",
    "e2e:core": "./scripts/playwright-docker.sh core-examples",
    "e2e:bootstrap": "./scripts/playwright-docker.sh bootstrap-examples",
    "e2e:material": "./scripts/playwright-docker.sh material-examples",
    "e2e:primeng": "./scripts/playwright-docker.sh primeng-examples",
    "e2e:ionic": "./scripts/playwright-docker.sh ionic-examples",
    "e2e:bootstrap:update": "./scripts/playwright-docker.sh bootstrap-examples --update-snapshots",
    "e2e:material:update": "./scripts/playwright-docker.sh material-examples --update-snapshots",
    "e2e:primeng:update": "./scripts/playwright-docker.sh primeng-examples --update-snapshots",
    "e2e:ionic:update": "./scripts/playwright-docker.sh ionic-examples --update-snapshots",
    "e2e:clean": "./scripts/clean-e2e-cache.sh",
    "clean": "nx reset && rm -rf dist node_modules/.cache",
    "mcp:build": "nx build dynamic-form-mcp",
    "mcp:dev": "nx build dynamic-form-mcp && node dist/packages/dynamic-form-mcp/bin/ng-forge-mcp.js",
    "mcp:smoke": "nx run dynamic-form-mcp:smoke",
    "release:branch:patch": "bash scripts/create-release-branch.sh patch",
    "release:branch:minor": "bash scripts/create-release-branch.sh minor",
    "release:branch:major": "bash scripts/create-release-branch.sh major"
  },
  "private": true,
