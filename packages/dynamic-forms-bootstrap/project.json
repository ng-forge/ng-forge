{
  "name": "dynamic-forms-bootstrap",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dynamic-forms-bootstrap/src",
  "prefix": "df-bs",
  "projectType": "library",
  "implicitDependencies": ["dynamic-forms"],
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}", "dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "//": "Empty configurations propagate to compile via dependsOn (Nx 22). See scripts/strip-fesm-comments.mjs header for the full pipeline.",
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "inputs": ["production", "^production"],
      "dependsOn": ["compile"],
      "options": {
        "command": "node scripts/strip-fesm-comments.mjs dist/packages/dynamic-forms-bootstrap",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "production": {},
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "compile": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "packages/dynamic-forms-bootstrap/ng-package.json",
        "tsConfig": "packages/dynamic-forms-bootstrap/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "packages/dynamic-forms-bootstrap/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@analogjs/vitest-angular:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "configFile": "vite.config.ts"
      }
    },
    "type-test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/dynamic-forms-bootstrap/vite.config.typecheck.ts"
      }
    },
    "api-check": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "cache": true,
      "inputs": [
        "{workspaceRoot}/dist/{projectRoot}/types/**/*.d.ts",
        "{projectRoot}/api-extractor.json",
        "{workspaceRoot}/config/api-extractor.base.json",
        "{workspaceRoot}/etc/dynamic-forms-bootstrap.api.md"
      ],
      "options": {
        "command": "api-extractor run --config packages/dynamic-forms-bootstrap/api-extractor.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "api-update": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "commands": [
          "nx run dynamic-forms-bootstrap:build --skip-nx-cache",
          "api-extractor run --local --config packages/dynamic-forms-bootstrap/api-extractor.json"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
