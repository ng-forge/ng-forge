{
  "name": "dynamic-forms",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dynamic-forms/src",
  "prefix": "lib",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}", "dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "//": "Empty configurations propagate to compile via dependsOn (Nx 22). See scripts/strip-fesm-comments.mjs header for the full pipeline.",
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "inputs": ["production", "^production"],
      "dependsOn": ["compile", "build-schematics"],
      "options": {
        "command": "node scripts/strip-fesm-comments.mjs dist/packages/dynamic-forms",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "production": {},
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "build-schematics": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/schematics"],
      "inputs": ["{projectRoot}/schematics/**/*", "!{projectRoot}/schematics/**/*.spec.ts"],
      "dependsOn": ["compile"],
      "options": {
        "commands": ["tsc -p packages/dynamic-forms/schematics/tsconfig.json", "node scripts/finalize-dynamic-forms-schematics.mjs"],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    },
    "test-schematics": {
      "executor": "@nx/vitest:test",
      "inputs": ["{projectRoot}/schematics/**/*", "{workspaceRoot}/dist/{projectRoot}/schematics/**/*"],
      "dependsOn": ["build-schematics"],
      "options": {
        "configFile": "packages/dynamic-forms/schematics/vitest.config.ts"
      }
    },
    "gen-public-api": {
      "//": "Regenerates internal/src/public_api.ts (export * from every internal module) before compile so the /internal barrel is always current. Replaces the old CI --check gate.",
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "node scripts/refactor/gen-public-api.mjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "compile": {
      "executor": "@nx/angular:package",
      "dependsOn": ["gen-public-api"],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "packages/dynamic-forms/ng-package.json",
        "tsConfig": "packages/dynamic-forms/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "packages/dynamic-forms/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "api-check": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "cache": true,
      "inputs": [
        "{workspaceRoot}/dist/{projectRoot}/types/**/*.d.ts",
        "{projectRoot}/api-extractor.json",
        "{projectRoot}/api-extractor.integration.json",
        "{projectRoot}/api-extractor.schema.json",
        "{workspaceRoot}/config/api-extractor.base.json",
        "{workspaceRoot}/etc/dynamic-forms.api.md",
        "{workspaceRoot}/etc/dynamic-forms-integration.api.md",
        "{workspaceRoot}/etc/dynamic-forms-schema.api.md"
      ],
      "options": {
        "commands": [
          "api-extractor run --config packages/dynamic-forms/api-extractor.json",
          "api-extractor run --config packages/dynamic-forms/api-extractor.integration.json",
          "api-extractor run --config packages/dynamic-forms/api-extractor.schema.json"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    },
    "api-update": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "cache": false,
      "options": {
        "commands": [
          "api-extractor run --local --config packages/dynamic-forms/api-extractor.json",
          "api-extractor run --local --config packages/dynamic-forms/api-extractor.integration.json",
          "api-extractor run --local --config packages/dynamic-forms/api-extractor.schema.json"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "@analogjs/vitest-angular:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "configFile": "vite.config.ts"
      }
    },
    "type-test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/dynamic-forms/vite.config.typecheck.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
