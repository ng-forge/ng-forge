{
  "name": "dynamic-form-mcp",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dynamic-form-mcp/src",
  "projectType": "library",
  "implicitDependencies": ["dynamic-forms-zod"],
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}", "dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": ["scope:mcp", "type:server"],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/dynamic-form-mcp",
        "main": "packages/dynamic-form-mcp/src/index.ts",
        "tsConfig": "packages/dynamic-form-mcp/tsconfig.lib.json",
        "format": ["esm"],
        "platform": "node",
        "bundle": true,
        "additionalEntryPoints": ["packages/dynamic-form-mcp/bin/ng-forge-mcp.ts"],
        "assets": [
          "packages/dynamic-form-mcp/README.md",
          "packages/dynamic-form-mcp/package.json",
          "packages/dynamic-form-mcp/src/registry/examples.json"
        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/dynamic-form-mcp/vite.config.ts"
      }
    },
    "api-check": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "cache": true,
      "inputs": [
        "{workspaceRoot}/dist/{projectRoot}/src/**/*.d.ts",
        "{projectRoot}/api-extractor.json",
        "{workspaceRoot}/config/api-extractor.base.json",
        "{workspaceRoot}/etc/dynamic-form-mcp.api.md"
      ],
      "options": {
        "command": "api-extractor run --config packages/dynamic-form-mcp/api-extractor.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "api-update": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "cache": false,
      "options": {
        "command": "api-extractor run --local --config packages/dynamic-form-mcp/api-extractor.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "smoke": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "cache": true,
      "inputs": [
        "{workspaceRoot}/dist/{projectRoot}/**/*.js",
        "{workspaceRoot}/dist/{projectRoot}/package.json",
        "{workspaceRoot}/scripts/mcp-smoke-test.mjs"
      ],
      "options": {
        "command": "node scripts/mcp-smoke-test.mjs",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
