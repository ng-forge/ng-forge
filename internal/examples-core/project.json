{
  "name": "examples-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "internal/examples-core/src",
  "prefix": "example",
  "projectType": "library",
  "tags": ["examples", "internal"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "dependsOn": ["^build"],
      "options": {
        "project": "internal/examples-core/ng-package.json",
        "tsConfig": "internal/examples-core/tsconfig.lib.json"
      }
    }
  }
}
